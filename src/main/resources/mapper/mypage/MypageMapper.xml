<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.gnagnoohc.travel.mypage.repository.MypageRepository">

    <select id="getMemberInfo" parameterType="long" resultType="com.gnagnoohc.travel.mypage.dto.MypageDto">
        select * from member where member_id = #{memberId}
    </select>

    <update id="updateMember" parameterType="com.gnagnoohc.travel.mypage.dto.MypageDto">
        update member set name = #{name}, nickname = #{nickname}, phone = #{phone} where member_id = #{memberId}
    </update>

    <!-- 비밀번호 저장 구조 확정 후 사용
    <update id="changePassword" parameterType="com.gnagnoohc.travel.mypage.dto.MypageDto">
        update member set password = #{newPassword} where member_id = #{memberId}
    </update>
    -->
    
    <select id="getReservationList" parameterType="long" resultType="com.gnagnoohc.travel.mypage.dto.MypageDto">
    select * from reservation where member_id = #{memberId} order by created_at desc
	</select>

</mapper>