<mapper namespace="com.gnagnoohc.travel.tour.mapper.TourMapper">

    <!-- 배치용 - 외부 공공데이터 수집 후 PLACE 테이블 알박기(UPSERT) -->
    <insert id="upsertPlace">
        INSERT INTO place (
            content_id, 
            title, 
            address, 
            tel, 
            overview, 
            is_closed
        ) VALUES (
            #{contentid}, 
            #{title}, 
            #{addr1}, 
            #{tel}, 
            #{overview}, 
            #{isClosed}
        )
        ON DUPLICATE KEY UPDATE
            title = VALUES(title),
            address = VALUES(address),
            tel = VALUES(tel),
            overview = VALUES(overview),
            is_closed = VALUES(is_closed);
    </insert>

    <!-- 서비스 조회용 - 사용자 서비스 쿼리 영역 -->
    <!-- 
