<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.gnagnoohc.travel.community.mapper.CommonMapper">
	<!-- ── 장소 태그 (place 테이블) ──
	     community(글쓰기/수정 시 장소 검색)와 comment(댓글 권한 체크) 양쪽에서
	     같이 쓰는 쿼리라서 common으로 분리함 -->

	<!-- 이름으로 장소 검색 (방문자인증후기 글쓰기/수정 시 태그할 장소 찾기용)
	     ※ place 테이블이 다른 팀원 담당 모듈에 이미 검색 쿼리가 있다면 그쪽으로 옮기는 게 맞음.
	        지금은 커뮤니티 쪽에서 바로 쓸 수 있게 여기에 추가함
	     ※ place 상호명 컬럼은 title (기존 name 컬럼 참조는 스키마와 안 맞아서 수정함) -->
	<select id="searchPlaces" parameterType="string" resultType="map">
		select place_id as placeId, title as name, place_type as placeType
		from place
		where title like concat('%', #{keyword}, '%')
		order by title asc
		limit 10
	</select>

	<!-- 댓글 권한 체크용: 게시글에 태그된 place의 소유주 member_id (place 미태그 글이면 결과 없음 → null) -->
	<select id="selectPlaceOwnerId" parameterType="int" resultType="int">
		select pl.member_id
		from post p
		join place pl on p.place_id = pl.place_id
		where p.post_id = #{postId}
	</select>
</mapper>